provider:
  baseUrl: https://hk.n1n.ai/v1
  fallbackBaseUrl: https://api.n1n.ai/v1
  model: qwen3.5-122b-a10b
  apiKeyEnv: N1N_API_KEY

scheduler:
  concurrency: 8
  timeoutSeconds: 60
  maxRetries: 2
  retryBaseDelayMs: 300
  retryMaxDelayMs: 2500
  circuitBreakerFailureThreshold: 3

analysis:
  longEdge: 1024
  jpegQuality: 85

cropProfiles:
  - ratio: 1:1
    longEdge: 1024
  - ratio: 3:4
    longEdge: 1536
