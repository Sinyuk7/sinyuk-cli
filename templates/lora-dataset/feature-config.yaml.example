provider:
  baseUrl: https://hk.n1n.ai/v1
  fallbackBaseUrl: https://api.n1n.ai/v1
  model: qwen3.5-122b-a10b
  apiKeyEnv: N1N_API_KEY

scheduler:
  concurrency: 8
  timeoutSeconds: 120
  maxRetries: 2
  retryBaseDelayMs: 300
  retryMaxDelayMs: 2500

analysis:
  longEdge: 896
  jpegQuality: 80

crop:
  ratioOptions:
    - 1:1
    - 2:3
    - 3:2
  resolutionOptions:
    - 1024
    - 1280
    - 1536
